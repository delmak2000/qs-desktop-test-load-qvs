// ============================================
// SAMPLE QLIK SENSE LOAD SCRIPT - TEST FILE
// ============================================
// Purpose: Test loading a script from a Gist
// Usage:   Paste directly into Data Load Editor
//          OR use $(Must_Include=[lib://...]);
// ============================================


// --- TABLE 1: Sales Data ---
SalesData_secret:
LOAD * INLINE [
    OrderID, Product,     Region,  SalesRep,    Amount, OrderDate
    1001,    Laptop,      North,   Alice,        1500,   2024-01-05
    1002,    Monitor,     South,   Bob,          400,    2024-01-10
    1003,    Keyboard,    East,    Carol,        80,     2024-01-15
    1004,    Laptop,      West,    Dave,         1500,   2024-02-01
    1005,    Mouse,       North,   Alice,        25,     2024-02-03
    1006,    Monitor,     East,    Carol,        400,    2024-02-14
    1007,    Headphones,  South,   Bob,          120,    2024-03-01
    1008,    Laptop,      North,   Eve,          1500,   2024-03-10
    1009,    Keyboard,    West,    Dave,         80,     2024-03-22
    1010,    Mouse,       South,   Eve,          25,     2024-03-30
];


// --- TABLE 2: Sales Targets ---
SalesTargets_secret:
LOAD * INLINE [
    Region,  Target
    North,   5000
    South,   4000
    East,    3500
    West,    4500
];


// --- TABLE 3: Product Categories ---
ProductInfo_secret:
LOAD * INLINE [
    Product,     Category,     UnitCost
    Laptop,      Computing,    1200
    Monitor,     Computing,    300
    Keyboard,    Accessories,  50
    Mouse,       Accessories,  15
    Headphones,  Audio,        80
];



// --- TABLE 4: Table4_secret --- 
Table4_secret:
LOAD * INLINE [
    TestX,     TestY,     TestZ
    XXXX,      YYYYY,    ZZZZ
];


// --- TABLE 5: Table5_secret ---
Table5_secret:
LOAD * INLINE [
    TestA,     TestB,     TestC
    AAAA,     BBBB,    CCCC
];


// --- TABLE 6: Table6_secret ---
Table6_secret:
LOAD * INLINE [
    TestC,     TestD,     TestE
    CCCC,     DDDD,    EEEE
];


// --- TABLE 7: Table7_secret ---
Table7_secret:
LOAD * INLINE [
    TestF,     TestG,     TestH
    FFFF,     GGGG,    HHHH
];


/*
Characters:
Load Chr(RecNo()+Ord('A')-1) as Alpha, RecNo() as Num autogenerate 26;
 
ASCII:
Load 
 if(RecNo()>=65 and RecNo()<=90,RecNo()-64) as Num,
 Chr(RecNo()) as AsciiAlpha, 
 RecNo() as AsciiNum
autogenerate 255
 Where (RecNo()>=32 and RecNo()<=126) or RecNo()>=160 ;
 
Transactions:
Load
 TransLineID, 
 TransID,
 mod(TransID,26)+1 as Num,
 Pick(Ceil(3*Rand1),'A','B','C') as Dim1,
 Pick(Ceil(6*Rand1),'a','b','c','d','e','f') as Dim2,
 Pick(Ceil(3*Rand()),'X','Y','Z') as Dim3,
 Round(1000*Rand()*Rand()*Rand1) as Expression1,
 Round(  10*Rand()*Rand()*Rand1) as Expression2,
 Round(Rand()*Rand1,0.00001) as Expression3;
Load 
 Rand() as Rand1,
 IterNo() as TransLineID,
 RecNo() as TransID
Autogenerate 1000
 While Rand()<=0.5 or IterNo()=1;

 Comment Field Dim1 With "This is a field comment";
*/


// ============================================
// END OF SCRIPT
// ============================================
