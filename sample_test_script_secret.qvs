// --- TABLE 1: Sales Data ---
SalesData_secret:
LOAD * INLINE [
    OrderID, Product,     Region,  SalesRep,    Amount, OrderDate
    1001,    Laptop,      North,   Alice,        1500,   2024-01-05
    1002,    Monitor,     South,   Bob,          400,    2024-01-10
    1003,    Keyboard,    East,    Carol,        80,     2024-01-15
    1004,    Laptop,      West,    Dave,         1500,   2024-02-01
    1005,    Mouse,       North,   Alice,        25,     2024-02-03
    1006,    Monitor,     East,    Carol,        400,    2024-02-14
    1007,    Headphones,  South,   Bob,          120,    2024-03-01
    1008,    Laptop,      North,   Eve,          1500,   2024-03-10
    1009,    Keyboard,    West,    Dave,         80,     2024-03-22
    1010,    Mouse,       South,   Eve,          25,     2024-03-30
];


// --- TABLE 2: Sales Targets ---
SalesTargets_secret:
LOAD * INLINE [
    Region,  Target
    North,   5000
    South,   4000
    East,    3500
    West,    4500
];


// --- TABLE 3: Product Categories ---
ProductInfo_secret:
LOAD * INLINE [
    Product,     Category,     UnitCost
    Laptop,      Computing,    1200
    Monitor,     Computing,    300
    Keyboard,    Accessories,  50
    Mouse,       Accessories,  15
    Headphones,  Audio,        80
];



// --- TABLE 4: Product Categories ---
Table4_secret:
LOAD * INLINE [
    TestX,     TestY,     TestZ
    XXXX,      YYYYY,    1200
];


// --- TABLE 5: Product Categories ---
Table5_secret:
LOAD * INLINE [
    TestA,     TestB,     TestC
    AAAA,     BBBB,    300
];


// ============================================
// END OF SCRIPT
